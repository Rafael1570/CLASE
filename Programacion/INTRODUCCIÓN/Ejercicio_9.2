Algoritmo Ejercicio_9_2
	Escribir "Dime 5 numeros"
	Leer primernumero
	Leer segundonumero
	Leer tercernumero
	Leer cuartonumero
	Leer quintonumero
	
	Dimension datos[5]
	datos[1] <- primernumero
	datos[2] <- segundonumero
	datos[3] <- tercernumero
	datos[4] <- cuartonumero
	datos[5] <- quintonumero
	
	Escribir (datos[1] + datos[2] + datos[3] + datos[4] + datos[5])/5
	
FinAlgoritmo
